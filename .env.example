# ---------------------------------------------------------------------------
# Clipflow — env contract
# Copy to .env.local and fill in the values. `lib/env.ts` validates these at
# module load and will throw at boot if anything is missing or malformed.
# ---------------------------------------------------------------------------

# Supabase (local dev values are printed by `pnpm db:start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM master key for BYOK AI-Key encryption.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# App URL — used for auth redirects AND Shotstack webhook callbacks.
# Set to your live domain in production (e.g. https://clipflow.to)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shotstack — Video rendering (BYOK, users bring their own key).
# Platform fallback key (optional — lets free-tier users try renders).
# Get your key at: https://dashboard.shotstack.io
SHOTSTACK_API_KEY=
SHOTSTACK_API_URL=https://api.shotstack.io/edit/v1
# Shared secret for POST /api/webhooks/shotstack.
# Generate with: openssl rand -hex 32
# Also add to Vercel env vars so production webhooks are verified.
SHOTSTACK_WEBHOOK_SECRET=

# Apify — scraper infrastructure for trending TikTok sounds + competitor
# intelligence. Get a personal token at:
# https://console.apify.com/account/integrations
# Pay-per-use: ~$0.002 per request. $5/mo free credit covers early dev.
APIFY_TOKEN=

# Google API key — YouTube Data API v3 (creator search + trending-keywords cron).
# OPTIONAL locally; without it the Research → Creators tab and the daily
# /api/cron/trends job will both return "Google API key not configured".
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "YouTube Data API v3" on the same project. Free quota: 10k units/day.
GOOGLE_API_KEY=

# Composio — managed OAuth for integrations (Notion, Google Drive, Sheets, etc.)
# One platform account covers all your users. Free tier: 20k tool calls/mo.
# Sign up at: https://composio.dev → Dashboard → API Keys
COMPOSIO_API_KEY=

# ---------------------------------------------------------------------------
# Cron + webhook secrets (all required in production)
# ---------------------------------------------------------------------------

# Shared secret for POST /api/cron/* endpoints. Must be ≥16 chars.
# Generate with: openssl rand -hex 32
# Vercel Cron sends this in the `authorization: Bearer $CRON_SECRET` header.
CRON_SECRET=

# ---------------------------------------------------------------------------
# Rate limiting (Upstash Redis) — OPTIONAL locally, REQUIRED in production
# ---------------------------------------------------------------------------
# No-ops locally when unset, so dev works fine without an account.
# In production: sign up at https://upstash.com → create Redis DB →
# copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Error tracking (Sentry) — OPTIONAL locally, RECOMMENDED in production
# ---------------------------------------------------------------------------
# No-ops when unset. Sign up at https://sentry.io → Create Project (Next.js).
#
# DSN appears in both client and server contexts — use the same value:
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source-map upload (build-time only):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Cron health monitoring (Healthchecks.io) — OPTIONAL
# ---------------------------------------------------------------------------
# No-ops when unset. Sign up at https://healthchecks.io → create one check
# per cron with matching schedule. Copy each ping URL here.
HEALTHCHECK_REAP_STUCK_ROWS_URL=
HEALTHCHECK_PUBLISH_SCHEDULED_URL=
HEALTHCHECK_FETCH_STATS_URL=
HEALTHCHECK_REAP_SOFT_DELETED_URL=

# ---------------------------------------------------------------------------
# Admin panel
# ---------------------------------------------------------------------------
# Comma-separated lowercase emails that can access /admin.
# Leave empty = nobody can access admin panel.
ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Email (Resend) — OPTIONAL locally, REQUIRED for welcome/review emails
# ---------------------------------------------------------------------------
# Sign up at https://resend.com → API Keys → Create
RESEND_API_KEY=
# Verified sender domain:
EMAIL_FROM=Clipflow <hello@clipflow.to>

# ---------------------------------------------------------------------------
# Stripe — REQUIRED for billing in production
# ---------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Referral program — create a coupon in Stripe dashboard, paste its ID here
STRIPE_REFERRAL_COUPON_ID=

# ---------------------------------------------------------------------------
# SEO — OPTIONAL but recommended (see docs/SEO.md)
# ---------------------------------------------------------------------------

# Search-engine ownership verification meta tags. Each goes through
# Metadata.verification in app/layout.tsx and emits a <meta> tag only
# when the env var is non-empty (no broken markup if unset).
# Get from: https://search.google.com/search-console (HTML tag method)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Get from: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_VERIFICATION=
# Get from: https://webmaster.yandex.com (only if targeting RU traffic)
NEXT_PUBLIC_YANDEX_VERIFICATION=

# CSP report endpoint. Sentry projects expose one at:
#   https://<org>.ingest.sentry.io/api/<project-id>/security/?sentry_key=<key>
# When unset, CSP-Report-Only header still emits — just without the
# `report-uri` directive (browsers will silently drop violation reports).
SENTRY_CSP_REPORT_URI=

# AggregateRating gate — DO NOT enable until ≥20 verified reviews exist
# on a single source (Trustpilot / G2 / Capterra). Synthetic counts
# trigger Google's review-spam manual penalty across the entire site.
NEXT_PUBLIC_REVIEW_RATING=
NEXT_PUBLIC_REVIEW_COUNT=
NEXT_PUBLIC_REVIEW_SOURCE_URL=

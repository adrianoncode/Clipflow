# ---------------------------------------------------------------------------
# Clipflow — env contract
# Copy to .env.local and fill in the values. `lib/env.ts` validates these at
# module load and will throw at boot if anything is missing or malformed.
# ---------------------------------------------------------------------------

# Supabase (local dev values are printed by `pnpm db:start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM master key for BYOK AI-Key encryption.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# App URL — used for auth redirects AND Shotstack webhook callbacks.
# Set to your live domain in production (e.g. https://clipflow.to)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shotstack — Video rendering (BYOK, users bring their own key).
# Platform fallback key (optional — lets free-tier users try renders).
# Get your key at: https://dashboard.shotstack.io
SHOTSTACK_API_KEY=
SHOTSTACK_API_URL=https://api.shotstack.io/edit/v1
# Shared secret for POST /api/webhooks/shotstack.
# Generate with: openssl rand -hex 32
# Also add to Vercel env vars so production webhooks are verified.
SHOTSTACK_WEBHOOK_SECRET=

# Apify — scraper infrastructure for trending TikTok sounds + competitor
# intelligence. Get a personal token at:
# https://console.apify.com/account/integrations
# Pay-per-use: ~$0.002 per request. $5/mo free credit covers early dev.
APIFY_TOKEN=

# Composio — managed OAuth for integrations (Notion, Google Drive, Sheets, etc.)
# One platform account covers all your users. Free tier: 20k tool calls/mo.
# Sign up at: https://composio.dev → Dashboard → API Keys
COMPOSIO_API_KEY=
